{
  "phase": 3,
  "name": "g7e EFA vs TCP Performance Comparison (Focused)",
  "description": "Focused comparison of EFA (UCX+SRD) vs TCP for KV-Cache transfer on g7e.12xlarge (Blackwell RTX PRO 6000). 3 TCP + 3 EFA patterns targeting large context where network overhead is dominant. Includes Unified baseline for overhead calculation.",
  "created": "2026-03-03",
  "mlflow_config": {
    "experiment_name": "nixl-efa-phase3",
    "timestamp_suffix": true
  },
  "infrastructure": {
    "instance_type": "g7e.12xlarge",
    "node_count": 2,
    "model": "Qwen/Qwen2.5-32B-Instruct",
    "model_size": "32B",
    "vllm_version": "v0.16.0",
    "nixl_version": "v0.10.0",
    "gpu_type": "NVIDIA RTX PRO 6000 Blackwell Server Edition 96GB",
    "gpu_count_per_node": 4,
    "tp_size": 4,
    "efa_bandwidth_gbps": 100,
    "region": "us-east-1",
    "placement_group": "cluster",
    "venv_path": ""
  },
  "common_settings": {
    "max_tokens": 128,
    "warmup_iterations": 5,
    "measurement_iterations": 30,
    "gpu_memory_utilization": 0.9,
    "max_num_batched_tokens": 8192,
    "measurement_type": "online",
    "temperature": 0,
