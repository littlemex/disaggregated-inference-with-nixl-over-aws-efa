# Phase 3 - us-west-2 Configuration (v3)
# Producer/Consumer separated configuration
# Stack: phase3-nixl-efa-dev-west-2
# Instance Type: g7e.12xlarge (RTX PRO 6000 Blackwell 96GB x2)
# Created: 2026-03-08

# ========================================
# AWS Configuration
# ========================================

S3_BUCKET="phase3-nixl-efa-dev-west-2-scriptsbucket40feb4b1-ougyvcmrbyjj"
AWS_REGION="us-west-2"

# ========================================
# EC2 Node Configuration
# ========================================

# Node1 (Producer)
NODE1_PUBLIC_IP="44.247.215.228"
NODE1_PRIVATE_IP="172.31.2.221"

# Node2 (Consumer)
NODE2_PUBLIC_IP="34.217.117.205"
NODE2_PRIVATE_IP="172.31.10.117"

# SSH configuration
SSH_KEY="/home/coder/.ssh/phase3_key"
REMOTE_USER="ubuntu"

# ========================================
# Producer Configuration
# ========================================

PRODUCER_ENGINE_ID="producer-phase3"
PRODUCER_PORT="8100"
PRODUCER_NIXL_ENGINE="producer"

# ========================================
# Consumer Configuration
# ========================================

CONSUMER_ENGINE_ID="consumer-phase3"
CONSUMER_PORT="8200"
CONSUMER_NIXL_ENGINE="consumer"

# ========================================
# NIXL Configuration (Common)
# ========================================

NIXL_PORT="14579"
NIXL_REPO="https://github.com/littlemex/nixl.git"
NIXL_BRANCH="main"
NIXL_CLONE_DIR="/tmp/nixl-build"
BUILD_SUBDIR="build"
PLUGIN_RELATIVE_PATH="src/plugins/libfabric/libplugin_LIBFABRIC.so"
S3_PLUGIN_KEY="plugins/libplugin_LIBFABRIC.so"

# ========================================
# vLLM Configuration (Common)
# ========================================

MODEL_NAME="Qwen/Qwen2.5-32B-Instruct"
TENSOR_PARALLEL_SIZE="2"
GPU_MEMORY_UTILIZATION="0.9"
MAX_MODEL_LEN="32000"
MAX_NUM_BATCHED_TOKENS="8192"
KV_BUFFER_SIZE="5000000000"
KV_BUFFER_DEVICE="cpu"
