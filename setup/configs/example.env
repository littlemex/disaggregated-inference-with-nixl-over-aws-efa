# NIXL Complete Deployment Configuration
#
# Copy this file and customize for your deployment:
#   cp configs/example.env configs/my-deployment.env
#   vim configs/my-deployment.env
#   ./deploy.sh configs/my-deployment.env

# ========================================
# AWS Configuration
# ========================================

# S3 bucket for NIXL plugin and scripts
S3_BUCKET="your-bucket-name"

# AWS region
AWS_REGION="us-west-2"

# ========================================
# EC2 Node Configuration
# ========================================

# Node1 (Producer)
NODE1_PUBLIC_IP="1.2.3.4"
NODE1_PRIVATE_IP="172.31.x.x"

# Node2 (Consumer)
NODE2_PUBLIC_IP="5.6.7.8"
NODE2_PRIVATE_IP="172.31.x.x"

# SSH configuration
SSH_KEY="/home/coder/.ssh/your-key.pem"
REMOTE_USER="ubuntu"

# ========================================
# NIXL Build Configuration (Optional)
# ========================================

# NIXL repository (default: https://github.com/littlemex/nixl.git)
# NIXL_REPO="https://github.com/littlemex/nixl.git"

# NIXL branch (default: main)
# NIXL_BRANCH="main"

# Build directory (default: /tmp/nixl-build)
# NIXL_CLONE_DIR="/tmp/nixl-build"

# Build subdirectory (default: build)
# BUILD_SUBDIR="build"

# Plugin relative path (default: src/plugins/libfabric/libplugin_LIBFABRIC.so)
# PLUGIN_RELATIVE_PATH="src/plugins/libfabric/libplugin_LIBFABRIC.so"

# S3 plugin key (default: plugins/libplugin_LIBFABRIC.so)
# S3_PLUGIN_KEY="plugins/libplugin_LIBFABRIC.so"

# ========================================
# vLLM Configuration (Optional)
# ========================================

# Model name (default: Qwen/Qwen2.5-32B-Instruct)
# MODEL_NAME="Qwen/Qwen2.5-32B-Instruct"

# Ports (defaults: 8100, 8200, 14579)
# PRODUCER_PORT="8100"
# CONSUMER_PORT="8200"
# NIXL_PORT="14579"

# Tensor parallelism (default: 2)
# TENSOR_PARALLEL_SIZE="2"

# GPU memory utilization (default: 0.9)
# GPU_MEMORY_UTILIZATION="0.9"

# Max model length (default: 32000)
# MAX_MODEL_LEN="32000"

# Max batched tokens (default: 8192)
# MAX_NUM_BATCHED_TOKENS="8192"

# KV buffer size (default: 5000000000)
# KV_BUFFER_SIZE="5000000000"
