#!/bin/bash
##
## Producer vLLM Server Startup Script
##
## Generated from template by v9 deployment
##

set -e
cd /home/${REMOTE_USER}

# Activate PyTorch environment
if [ -f /opt/pytorch/bin/activate ]; then
    source /opt/pytorch/bin/activate
fi

NIXL_DIR=$(python3 -c "import nixl, os; print(os.path.dirname(nixl.__file__))")
export NIXL_PLUGIN_DIR="${NIXL_DIR}/_lib"
export FI_PROVIDER=efa
export FI_LOG_LEVEL=debug
export VLLM_NIXL_SIDE_CHANNEL_HOST=${NODE1_PRIVATE_IP}
export VLLM_NIXL_SIDE_CHANNEL_PORT=${ZMQ_PORT}
export NIXL_LOG_LEVEL=TRACE
export VLLM_LOGGING_LEVEL=DEBUG

KV_CONFIG=$(cat /home/${REMOTE_USER}/kv_config.json)

nohup python3 -m vllm.entrypoints.openai.api_server \
  --model ${MODEL_NAME} \
  --port ${PRODUCER_PORT} \
  --tensor-parallel-size ${TENSOR_PARALLEL_SIZE} \
  --distributed-executor-backend mp \
  --gpu-memory-utilization ${GPU_MEMORY_UTILIZATION} \
  --max-model-len ${MAX_MODEL_LEN} \
  --max-num-batched-tokens ${MAX_NUM_BATCHED_TOKENS} \
  --kv-transfer-config "$KV_CONFIG" \
  > /home/${REMOTE_USER}/producer.log 2>&1 &

echo $! > /home/${REMOTE_USER}/producer.pid
echo "[INFO] Producer started with PID: $(cat /home/${REMOTE_USER}/producer.pid)"
