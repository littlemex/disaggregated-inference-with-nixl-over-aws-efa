{
  "name": "Complete NIXL LIBFABRIC Deployment - v4 (Environment Variable Mapping)",
  "description": "完全自動化デプロイメント。Producer/Consumer で環境変数を適切にマッピング（AA=${AA_PRODUCER} 形式）。Phase 3 の成功パターンを完全再現。",
  "environment": {
    "NIXL_REPO": "${NIXL_REPO:-https://github.com/littlemex/nixl.git}",
    "NIXL_BRANCH": "${NIXL_BRANCH:-main}",
    "NIXL_CLONE_DIR": "${NIXL_CLONE_DIR:-/tmp/nixl-build}",
    "BUILD_SUBDIR": "${BUILD_SUBDIR:-build}",
    "PLUGIN_RELATIVE_PATH": "${PLUGIN_RELATIVE_PATH:-src/plugins/libfabric/libplugin_LIBFABRIC.so}",
    "S3_BUCKET": "${S3_BUCKET}",
    "S3_PLUGIN_KEY": "${S3_PLUGIN_KEY:-plugins/libplugin_LIBFABRIC.so}",
    "AWS_REGION": "${AWS_REGION}",
    "SSH_KEY": "${SSH_KEY}",
    "REMOTE_USER": "${REMOTE_USER:-ubuntu}",
    "NODE1_PUBLIC_IP": "${NODE1_PUBLIC_IP}",
    "NODE1_PRIVATE_IP": "${NODE1_PRIVATE_IP}",
    "NODE2_PUBLIC_IP": "${NODE2_PUBLIC_IP}",
    "NODE2_PRIVATE_IP": "${NODE2_PRIVATE_IP}",
    "PRODUCER_ENGINE_ID": "${PRODUCER_ENGINE_ID:-producer-1}",
    "PRODUCER_PORT": "${PRODUCER_PORT:-8100}",
    "PRODUCER_NIXL_ENGINE": "${PRODUCER_NIXL_ENGINE:-producer}",
    "CONSUMER_ENGINE_ID": "${CONSUMER_ENGINE_ID:-consumer-1}",
    "CONSUMER_PORT": "${CONSUMER_PORT:-8200}",
    "CONSUMER_NIXL_ENGINE": "${CONSUMER_NIXL_ENGINE:-consumer}",
    "NIXL_PORT": "${NIXL_PORT:-14579}",
    "MODEL_NAME": "${MODEL_NAME:-Qwen/Qwen2.5-32B-Instruct}",
    "TENSOR_PARALLEL_SIZE": "${TENSOR_PARALLEL_SIZE:-2}",
    "GPU_MEMORY_UTILIZATION": "${GPU_MEMORY_UTILIZATION:-0.9}",
    "MAX_MODEL_LEN": "${MAX_MODEL_LEN:-32000}",
    "MAX_NUM_BATCHED_TOKENS": "${MAX_NUM_BATCHED_TOKENS:-8192}",
    "KV_BUFFER_SIZE": "${KV_BUFFER_SIZE:-5000000000}",
    "KV_BUFFER_DEVICE": "${KV_BUFFER_DEVICE:-cpu}"
  },
  "tasks": [
    {
      "id": "00-check-libfabric-dev",
      "name": "Check libfabric-dev installation",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Checking libfabric-dev installation...'",
        "if ! dpkg -l | grep -q libfabric-dev; then",
        "  echo '[ERROR] libfabric-dev is not installed'",
        "  echo ''",
        "  echo 'Please install libfabric-dev first:'",
        "  echo '  sudo apt-get update'",
        "  echo '  sudo apt-get install -y libfabric-dev'",
        "  echo ''",
        "  exit 1",
        "fi",
        "echo '[OK] libfabric-dev is installed'"
      ]
    },
    {
      "id": "01-check-local-prerequisites",
      "name": "Check local prerequisites",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Checking local prerequisites...'",
        "command -v git >/dev/null 2>&1 || { echo '[ERROR] git not found'; exit 1; }",
        "command -v ninja >/dev/null 2>&1 || { echo '[ERROR] ninja not found'; exit 1; }",
        "command -v meson >/dev/null 2>&1 || { echo '[ERROR] meson not found'; exit 1; }",
        "command -v aws >/dev/null 2>&1 || { echo '[ERROR] aws CLI not found'; exit 1; }",
        "echo '[OK] All prerequisites satisfied'"
      ]
    },
    {
      "id": "02-clone-nixl-from-github",
      "name": "Clone NIXL from GitHub",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Cloning NIXL from GitHub...'",
        "if [ -d \"${NIXL_CLONE_DIR}/.git\" ]; then",
        "  cd \"${NIXL_CLONE_DIR}\" && git fetch origin && git checkout ${NIXL_BRANCH} && git pull origin ${NIXL_BRANCH}",
        "else",
        "  rm -rf \"${NIXL_CLONE_DIR}\" && git clone \"${NIXL_REPO}\" \"${NIXL_CLONE_DIR}\" && cd \"${NIXL_CLONE_DIR}\" && git checkout ${NIXL_BRANCH}",
        "fi",
        "cd \"${NIXL_CLONE_DIR}\" && git log --oneline -1",
        "echo '[OK] NIXL source ready'"
      ]
    },
    {
      "id": "03-verify-request-response-protocol",
      "name": "Verify Request/Response protocol",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Verifying Request/Response protocol...'",
        "grep -q 'loadRemoteConnInfo' \"${NIXL_CLONE_DIR}/src/plugins/libfabric/libfabric_backend.h\" || { echo '[ERROR] loadRemoteConnInfo not found'; exit 1; }",
        "grep -q 'remote_conn_info' \"${NIXL_CLONE_DIR}/src/plugins/libfabric/libfabric_backend.cpp\" || { echo '[ERROR] remote_conn_info not found'; exit 1; }",
        "echo '[OK] Request/Response protocol verified'"
      ]
    },
    {
      "id": "04-setup-meson-build",
      "name": "Setup meson build",
      "skip_if": "test -f ${NIXL_CLONE_DIR}/${BUILD_SUBDIR}/build.ninja",
      "commands": [
        "echo '[INFO] Setting up meson build...'",
        "cd \"${NIXL_CLONE_DIR}\" && meson setup ${BUILD_SUBDIR} --prefix=/usr/local",
        "echo '[OK] Meson configured'"
      ]
    },
    {
      "id": "05-build-nixl-plugin",
      "name": "Build NIXL plugin",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Building NIXL plugin...'",
        "cd \"${NIXL_CLONE_DIR}/${BUILD_SUBDIR}\" && ninja",
        "test -f \"${NIXL_CLONE_DIR}/${BUILD_SUBDIR}/${PLUGIN_RELATIVE_PATH}\" || { echo '[ERROR] Build failed'; exit 1; }",
        "echo '[OK] Plugin built'"
      ]
    },
    {
      "id": "06-verify-plugin",
      "name": "Verify plugin artifact",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Verifying plugin...'",
        "PLUGIN_PATH=\"${NIXL_CLONE_DIR}/${BUILD_SUBDIR}/${PLUGIN_RELATIVE_PATH}\"",
        "SO_SIZE_KB=$(($(stat -c '%s' \"${PLUGIN_PATH}\") / 1024))",
        "echo \"[OK] Size: ${SO_SIZE_KB} KB\"",
        "file \"${PLUGIN_PATH}\" | grep -q 'ELF.*shared object' || { echo '[ERROR] Invalid ELF'; exit 1; }",
        "echo '[OK] Plugin verified'"
      ]
    },
    {
      "id": "07-upload-to-s3",
      "name": "Upload to S3",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Uploading to S3...'",
        "PLUGIN_PATH=\"${NIXL_CLONE_DIR}/${BUILD_SUBDIR}/${PLUGIN_RELATIVE_PATH}\"",
        "aws s3 cp \"${PLUGIN_PATH}\" \"s3://${S3_BUCKET}/${S3_PLUGIN_KEY}\" --region ${AWS_REGION}",
        "aws s3 ls \"s3://${S3_BUCKET}/${S3_PLUGIN_KEY}\" --region ${AWS_REGION} || { echo '[ERROR] Upload failed'; exit 1; }",
        "echo '[OK] Uploaded to S3'"
      ]
    },
    {
      "id": "08-check-connectivity",
      "name": "Check SSH connectivity",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Testing SSH...'",
        "ssh -i \"${SSH_KEY}\" -o StrictHostKeyChecking=no -o ConnectTimeout=10 \"${REMOTE_USER}@${NODE1_PUBLIC_IP}\" 'echo \"[OK] Node1\"' || { echo '[ERROR] Node1 unreachable'; exit 1; }",
        "ssh -i \"${SSH_KEY}\" -o StrictHostKeyChecking=no -o ConnectTimeout=10 \"${REMOTE_USER}@${NODE2_PUBLIC_IP}\" 'echo \"[OK] Node2\"' || { echo '[ERROR] Node2 unreachable'; exit 1; }",
        "echo '[OK] SSH connectivity verified'"
      ]
    },
    {
      "id": "09-setup-producer",
      "name": "Setup Producer (Node1)",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Setting up Producer...'",
        "ssh -i \"${SSH_KEY}\" -o StrictHostKeyChecking=no \"${REMOTE_USER}@${NODE1_PUBLIC_IP}\" bash -s << 'REMOTE_SCRIPT'",
        "set -e",
        "echo '[1/6] Installing vLLM v0.17.0...'",
        "python3 -m pip install --no-cache-dir 'vllm==0.17.0' --user -q",
        "python3 -c 'import vllm; print(f\"[OK] vLLM {vllm.__version__}\")'",
        "echo '[2/6] Installing NIXL v0.10.0...'",
        "python3 -m pip install --no-cache-dir 'nixl[cu12]' --user -q",
        "python3 -c 'import nixl; print(\"[OK] NIXL installed\")'",
        "echo '[3/6] Deploying LIBFABRIC plugin...'",
        "NIXL_DIR=$(python3 -c 'import nixl, os; print(os.path.dirname(nixl.__file__))')",
        "PLUGIN_DIR=\"${NIXL_DIR}/_lib\"",
        "aws s3 cp \"s3://${S3_BUCKET}/${S3_PLUGIN_KEY}\" \"${PLUGIN_DIR}/libplugin_LIBFABRIC.so\" --region ${AWS_REGION} --quiet",
        "chmod 755 \"${PLUGIN_DIR}/libplugin_LIBFABRIC.so\"",
        "ls -lh \"${PLUGIN_DIR}/libplugin_LIBFABRIC.so\"",
        "echo '[4/6] Creating environment file...'",
        "mkdir -p ~/nixl-producer",
        "cat > ~/nixl-producer/.env << 'ENV_EOF'",
        "# Producer environment variables",
        "# Mapped from PRODUCER_* to application expected names",
        "export ENGINE_ID=\"${PRODUCER_ENGINE_ID}\"",
        "export NIXL_ENGINE=\"${PRODUCER_NIXL_ENGINE}\"",
        "export NIXL_PORT=\"${NIXL_PORT}\"",
        "export KV_BUFFER_DEVICE=\"${KV_BUFFER_DEVICE}\"",
        "export CONSUMER_ADDR=\"${NODE2_PRIVATE_IP}:${CONSUMER_PORT}\"",
        "export VLLM_PORT=\"${PRODUCER_PORT}\"",
        "export MODEL_NAME=\"${MODEL_NAME}\"",
        "export TENSOR_PARALLEL_SIZE=\"${TENSOR_PARALLEL_SIZE}\"",
        "export GPU_MEMORY_UTILIZATION=\"${GPU_MEMORY_UTILIZATION}\"",
        "export MAX_MODEL_LEN=\"${MAX_MODEL_LEN}\"",
        "export MAX_NUM_BATCHED_TOKENS=\"${MAX_NUM_BATCHED_TOKENS}\"",
        "export KV_BUFFER_SIZE=\"${KV_BUFFER_SIZE}\"",
        "ENV_EOF",
        "echo '[5/6] Creating startup script...'",
        "cat > ~/nixl-producer/start.sh << 'SCRIPT_EOF'",
        "#!/bin/bash",
        "set -euo pipefail",
        "cd \"$(dirname \"$0\")\"",
        "source .env",
        "echo \"[INFO] Starting Producer...\"",
        "echo \"  ENGINE_ID: $ENGINE_ID\"",
        "echo \"  NIXL_ENGINE: $NIXL_ENGINE\"",
        "echo \"  Port: $VLLM_PORT\"",
        "echo \"  Consumer: $CONSUMER_ADDR\"",
        "vllm serve \"$MODEL_NAME\" \\",
        "  --port \"$VLLM_PORT\" \\",
        "  --tensor-parallel-size \"$TENSOR_PARALLEL_SIZE\" \\",
        "  --gpu-memory-utilization \"$GPU_MEMORY_UTILIZATION\" \\",
        "  --max-model-len \"$MAX_MODEL_LEN\" \\",
        "  --max-num-batched-tokens \"$MAX_NUM_BATCHED_TOKENS\" \\",
        "  --kv-buffer-size \"$KV_BUFFER_SIZE\" \\",
        "  --kv-buffer-device \"$KV_BUFFER_DEVICE\" \\",
        "  --trust-remote-code",
        "SCRIPT_EOF",
        "chmod +x ~/nixl-producer/start.sh",
        "echo '[6/6] Verifying...'",
        "python3 -c 'import nixl, os; d=os.path.join(os.path.dirname(nixl.__file__),\"_lib\"); print(f\"[OK] {len([f for f in os.listdir(d) if \"LIBFABRIC\" in f])} LIBFABRIC plugin(s)\")'",
        "echo '[SUCCESS] Producer setup complete'",
        "REMOTE_SCRIPT",
        "echo '[OK] Producer ready'"
      ]
    },
    {
      "id": "10-setup-consumer",
      "name": "Setup Consumer (Node2)",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Setting up Consumer...'",
        "ssh -i \"${SSH_KEY}\" -o StrictHostKeyChecking=no \"${REMOTE_USER}@${NODE2_PUBLIC_IP}\" bash -s << 'REMOTE_SCRIPT'",
        "set -e",
        "echo '[1/6] Installing vLLM v0.17.0...'",
        "python3 -m pip install --no-cache-dir 'vllm==0.17.0' --user -q",
        "python3 -c 'import vllm; print(f\"[OK] vLLM {vllm.__version__}\")'",
        "echo '[2/6] Installing NIXL v0.10.0...'",
        "python3 -m pip install --no-cache-dir 'nixl[cu12]' --user -q",
        "python3 -c 'import nixl; print(\"[OK] NIXL installed\")'",
        "echo '[3/6] Deploying LIBFABRIC plugin...'",
        "NIXL_DIR=$(python3 -c 'import nixl, os; print(os.path.dirname(nixl.__file__))')",
        "PLUGIN_DIR=\"${NIXL_DIR}/_lib\"",
        "aws s3 cp \"s3://${S3_BUCKET}/${S3_PLUGIN_KEY}\" \"${PLUGIN_DIR}/libplugin_LIBFABRIC.so\" --region ${AWS_REGION} --quiet",
        "chmod 755 \"${PLUGIN_DIR}/libplugin_LIBFABRIC.so\"",
        "ls -lh \"${PLUGIN_DIR}/libplugin_LIBFABRIC.so\"",
        "echo '[4/6] Creating environment file...'",
        "mkdir -p ~/nixl-consumer",
        "cat > ~/nixl-consumer/.env << 'ENV_EOF'",
        "# Consumer environment variables",
        "# Mapped from CONSUMER_* to application expected names",
        "export ENGINE_ID=\"${CONSUMER_ENGINE_ID}\"",
        "export NIXL_ENGINE=\"${CONSUMER_NIXL_ENGINE}\"",
        "export NIXL_PORT=\"${NIXL_PORT}\"",
        "export KV_BUFFER_DEVICE=\"${KV_BUFFER_DEVICE}\"",
        "export VLLM_PORT=\"${CONSUMER_PORT}\"",
        "export MODEL_NAME=\"${MODEL_NAME}\"",
        "export TENSOR_PARALLEL_SIZE=\"${TENSOR_PARALLEL_SIZE}\"",
        "export GPU_MEMORY_UTILIZATION=\"${GPU_MEMORY_UTILIZATION}\"",
        "export MAX_MODEL_LEN=\"${MAX_MODEL_LEN}\"",
        "export MAX_NUM_BATCHED_TOKENS=\"${MAX_NUM_BATCHED_TOKENS}\"",
        "export KV_BUFFER_SIZE=\"${KV_BUFFER_SIZE}\"",
        "ENV_EOF",
        "echo '[5/6] Creating startup script...'",
        "cat > ~/nixl-consumer/start.sh << 'SCRIPT_EOF'",
        "#!/bin/bash",
        "set -euo pipefail",
        "cd \"$(dirname \"$0\")\"",
        "source .env",
        "echo \"[INFO] Starting Consumer...\"",
        "echo \"  ENGINE_ID: $ENGINE_ID\"",
        "echo \"  NIXL_ENGINE: $NIXL_ENGINE\"",
        "echo \"  Port: $VLLM_PORT\"",
        "vllm serve \"$MODEL_NAME\" \\",
        "  --port \"$VLLM_PORT\" \\",
        "  --tensor-parallel-size \"$TENSOR_PARALLEL_SIZE\" \\",
        "  --gpu-memory-utilization \"$GPU_MEMORY_UTILIZATION\" \\",
        "  --max-model-len \"$MAX_MODEL_LEN\" \\",
        "  --max-num-batched-tokens \"$MAX_NUM_BATCHED_TOKENS\" \\",
        "  --kv-buffer-size \"$KV_BUFFER_SIZE\" \\",
        "  --kv-buffer-device \"$KV_BUFFER_DEVICE\" \\",
        "  --trust-remote-code",
        "SCRIPT_EOF",
        "chmod +x ~/nixl-consumer/start.sh",
        "echo '[6/6] Verifying...'",
        "python3 -c 'import nixl, os; d=os.path.join(os.path.dirname(nixl.__file__),\"_lib\"); print(f\"[OK] {len([f for f in os.listdir(d) if \"LIBFABRIC\" in f])} LIBFABRIC plugin(s)\")'",
        "echo '[SUCCESS] Consumer setup complete'",
        "REMOTE_SCRIPT",
        "echo '[OK] Consumer ready'"
      ]
    },
    {
      "id": "11-summary",
      "name": "Display summary",
      "skip_if": "",
      "commands": [
        "echo ''",
        "echo '========================================='",
        "echo 'Deployment Complete!'",
        "echo '========================================='",
        "echo ''",
        "echo 'Producer (Node1): ${NODE1_PUBLIC_IP}'",
        "echo '  ENGINE_ID: ${PRODUCER_ENGINE_ID}'",
        "echo '  Start: ssh -i ${SSH_KEY} ${REMOTE_USER}@${NODE1_PUBLIC_IP} \"cd ~/nixl-producer && ./start.sh\"'",
        "echo ''",
        "echo 'Consumer (Node2): ${NODE2_PUBLIC_IP}'",
        "echo '  ENGINE_ID: ${CONSUMER_ENGINE_ID}'",
        "echo '  Start: ssh -i ${SSH_KEY} ${REMOTE_USER}@${NODE2_PUBLIC_IP} \"cd ~/nixl-consumer && ./start.sh\"'",
        "echo ''"
      ]
    }
  ]
}
