{
  "name": "Complete NIXL LIBFABRIC Deployment - Full Reproduction",
  "description": "完全自動化されたデプロイメント: GitHub clone → ビルド → S3 → EC2セットアップ → vLLM起動。実際のus-west-2インスタンスの設定に基づく完全再現。",
  "environment": {
    "NIXL_REPO": "https://github.com/littlemex/nixl.git",
    "NIXL_BRANCH": "main",
    "NIXL_CLONE_DIR": "/tmp/nixl-build",
    "BUILD_SUBDIR": "build",
    "PLUGIN_RELATIVE_PATH": "src/plugins/libfabric/libplugin_LIBFABRIC.so",
    "S3_BUCKET": "phase3-nixl-efa-dev-west-2-scriptsbucket40feb4b1-ougyvcmrbyjj",
    "S3_PLUGIN_KEY": "plugins/libplugin_LIBFABRIC.so",
    "S3_SCRIPTS_PREFIX": "scripts/deployment",
    "AWS_REGION": "us-west-2",
    "SSH_KEY": "/home/coder/.ssh/phase3_key",
    "NODE1_PUBLIC_IP": "44.247.215.228",
    "NODE2_PUBLIC_IP": "34.217.117.205",
    "NODE1_PRIVATE_IP": "172.31.2.221",
    "NODE2_PRIVATE_IP": "172.31.10.117",
    "REMOTE_USER": "ubuntu",
    "MODEL_NAME": "Qwen/Qwen2.5-32B-Instruct",
    "PRODUCER_PORT": "8100",
    "CONSUMER_PORT": "8200",
    "NIXL_PORT": "14579",
    "TENSOR_PARALLEL_SIZE": "2",
    "GPU_MEMORY_UTILIZATION": "0.9",
    "MAX_MODEL_LEN": "32000",
    "MAX_NUM_BATCHED_TOKENS": "8192",
    "KV_BUFFER_SIZE": "5000000000"
  },
  "tasks": [
    {
      "id": "01-check-local-prerequisites",
      "name": "Check local prerequisites (git, ninja, meson, aws)",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Checking local prerequisites...'",
        "command -v git >/dev/null 2>&1 || { echo '[ERROR] git not found'; exit 1; }",
        "command -v ninja >/dev/null 2>&1 || { echo '[ERROR] ninja not found'; exit 1; }",
        "command -v meson >/dev/null 2>&1 || { echo '[ERROR] meson not found'; exit 1; }",
        "command -v aws >/dev/null 2>&1 || { echo '[ERROR] aws CLI not found'; exit 1; }",
        "echo '[OK] All prerequisites satisfied'"
      ]
    },
    {
      "id": "02-clone-nixl-from-github",
      "name": "Clone or update NIXL from GitHub",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Cloning NIXL from GitHub...'",
        "if [ -d \"${NIXL_CLONE_DIR}/.git\" ]; then cd \"${NIXL_CLONE_DIR}\" && git fetch origin && git checkout ${NIXL_BRANCH} && git pull origin ${NIXL_BRANCH}; else rm -rf \"${NIXL_CLONE_DIR}\" && git clone \"${NIXL_REPO}\" \"${NIXL_CLONE_DIR}\" && cd \"${NIXL_CLONE_DIR}\" && git checkout ${NIXL_BRANCH}; fi",
        "cd \"${NIXL_CLONE_DIR}\" && git log --oneline -1",
        "echo '[OK] NIXL source ready'"
      ]
    },
    {
      "id": "03-verify-backend-fix",
      "name": "Verify LIBFABRIC backend fix in source",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Verifying backend fix...'",
        "grep -q 'std::string conn_info_' \"${NIXL_CLONE_DIR}/src/plugins/libfabric/libfabric_backend.h\" || { echo '[ERROR] Fix not found'; exit 1; }",
        "grep -q 'str = conn_info_' \"${NIXL_CLONE_DIR}/src/plugins/libfabric/libfabric_backend.cpp\" || { echo '[ERROR] Fix not found'; exit 1; }",
        "echo '[OK] Backend fix verified'"
      ]
    },
    {
      "id": "04-setup-meson-build",
      "name": "Setup meson build directory",
      "skip_if": "test -f ${NIXL_CLONE_DIR}/${BUILD_SUBDIR}/build.ninja",
      "commands": [
        "echo '[INFO] Setting up meson build...'",
        "cd \"${NIXL_CLONE_DIR}\" && meson setup ${BUILD_SUBDIR} --prefix=/usr/local",
        "echo '[OK] Meson configured'"
      ]
    },
    {
      "id": "05-build-nixl-plugin",
      "name": "Build NIXL LIBFABRIC plugin",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Building NIXL plugin...'",
        "cd \"${NIXL_CLONE_DIR}/${BUILD_SUBDIR}\" && ninja ${PLUGIN_RELATIVE_PATH}",
        "PLUGIN_PATH=\"${NIXL_CLONE_DIR}/${BUILD_SUBDIR}/${PLUGIN_RELATIVE_PATH}\"",
        "test -f \"${PLUGIN_PATH}\" || { echo '[ERROR] Build failed'; exit 1; }",
        "echo \"[OK] Plugin built: $(stat -c '%s' \"${PLUGIN_PATH}\") bytes\""
      ]
    },
    {
      "id": "06-create-deployment-scripts",
      "name": "Create deployment scripts for EC2",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Creating deployment scripts...'",
        "mkdir -p /tmp/deployment-scripts",
        "cat > /tmp/deployment-scripts/setup-node.sh << 'EOSCRIPT'",
        "#!/bin/bash",
        "set -e",
        "NODE_ROLE=\"$1\"  # producer or consumer",
        "CONSUMER_PRIVATE_IP=\"$2\"",
        "S3_BUCKET=\"$3\"",
        "AWS_REGION=\"$4\"",
        "MODEL_NAME=\"$5\"",
        "PORT=\"$6\"",
        "",
        "echo \"[INFO] Setting up ${NODE_ROLE} node...\"",
        "",
        "# Install vLLM v0.17.0",
        "if ! python3 -c 'import vllm' 2>/dev/null; then",
        "  echo '[INFO] Installing vLLM v0.17.0...'",
        "  python3 -m pip install --no-cache-dir 'vllm==0.17.0' --user -q",
        "fi",
        "python3 -c 'import vllm; print(f\"[OK] vLLM {vllm.__version__}\")'",
        "",
        "# Install NIXL",
        "if ! python3 -c 'import nixl' 2>/dev/null; then",
        "  echo '[INFO] Installing NIXL...'",
        "  python3 -m pip install --no-cache-dir 'nixl[cu12]' --user -q",
        "fi",
        "python3 -c 'import nixl; print(\"[OK] NIXL installed\")'",
        "",
        "# Deploy LIBFABRIC plugin",
        "echo '[INFO] Deploying LIBFABRIC plugin...'",
        "NIXL_DIR=$(python3 -c 'import nixl; import os; print(os.path.dirname(nixl.__file__))')",
        "PLUGIN_DIR=\"${NIXL_DIR}/../.nixl_cu12.mesonpy.libs/plugins\"",
        "if [ ! -d \"${PLUGIN_DIR}\" ]; then",
        "  PLUGIN_DIR=\"${NIXL_DIR}/_lib\"",
        "fi",
        "mkdir -p \"${PLUGIN_DIR}\"",
        "",
        "# Backup original",
        "if [ ! -f \"${PLUGIN_DIR}/libplugin_LIBFABRIC.so.original\" ]; then",
        "  cp \"${PLUGIN_DIR}/libplugin_LIBFABRIC.so\" \"${PLUGIN_DIR}/libplugin_LIBFABRIC.so.original\" 2>/dev/null || true",
        "fi",
        "",
        "# Download from S3",
        "aws s3 cp \"s3://${S3_BUCKET}/plugins/libplugin_LIBFABRIC.so\" /tmp/libplugin_LIBFABRIC.so --region ${AWS_REGION} --quiet",
        "cp /tmp/libplugin_LIBFABRIC.so \"${PLUGIN_DIR}/libplugin_LIBFABRIC.so\"",
        "chmod 755 \"${PLUGIN_DIR}/libplugin_LIBFABRIC.so\"",
        "echo \"[OK] Plugin deployed: $(ls -lh \"${PLUGIN_DIR}/libplugin_LIBFABRIC.so\")\"",
        "",
        "# Verify NIXL loads plugin",
        "python3 -c 'from nixl._api import nixl_agent, nixl_agent_config; import uuid; cfg = nixl_agent_config(); agent = nixl_agent(str(uuid.uuid4()), cfg); plugins = agent.get_plugin_list(); assert \"LIBFABRIC\" in plugins'",
        "echo '[OK] NIXL can load LIBFABRIC plugin'",
        "",
        "# Create vLLM startup script",
        "if [ \"${NODE_ROLE}\" = \"producer\" ]; then",
        "  KV_ROLE='kv_producer'",
        "  KV_IP=\"${CONSUMER_PRIVATE_IP}\"",
        "else",
        "  KV_ROLE='kv_consumer'",
        "  KV_IP='127.0.0.1'",
        "fi",
        "",
        "cat > /tmp/start-vllm.sh << EOVLLM",
        "#!/bin/bash",
        "python3 -m vllm.entrypoints.openai.api_server \\\\",
        "  --model ${MODEL_NAME} \\\\",
        "  --port ${PORT} \\\\",
        "  --tensor-parallel-size 2 \\\\",
        "  --gpu-memory-utilization 0.9 \\\\",
        "  --max-model-len 32000 \\\\",
        "  --max-num-batched-tokens 8192 \\\\",
        "  --kv-transfer-config '{",
        "    \\\"kv_connector\\\": \\\"NixlConnector\\\",",
        "    \\\"kv_role\\\": \\\"${KV_ROLE}\\\",",
        "    \\\"kv_rank\\\": 0,",
        "    \\\"kv_parallel_size\\\": 1,",
        "    \\\"kv_buffer_device\\\": \\\"cpu\\\",",
        "    \\\"kv_buffer_size\\\": 5000000000,",
        "    \\\"kv_ip\\\": \\\"${KV_IP}\\\",",
        "    \\\"kv_port\\\": 14579,",
        "    \\\"kv_connector_extra_config\\\": {\\\"backends\\\": [\\\"LIBFABRIC\\\"]}",
        "  }'",
        "EOVLLM",
        "chmod +x /tmp/start-vllm.sh",
        "",
        "echo '[SUCCESS] Node setup complete!'",
        "echo '[INFO] To start vLLM, run: /tmp/start-vllm.sh'",
        "EOSCRIPT",
        "chmod +x /tmp/deployment-scripts/setup-node.sh",
        "echo '[OK] Deployment script created'"
      ]
    },
    {
      "id": "07-upload-to-s3",
      "name": "Upload plugin and scripts to S3",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Uploading to S3...'",
        "PLUGIN_PATH=\"${NIXL_CLONE_DIR}/${BUILD_SUBDIR}/${PLUGIN_RELATIVE_PATH}\"",
        "aws s3 cp \"${PLUGIN_PATH}\" \"s3://${S3_BUCKET}/${S3_PLUGIN_KEY}\" --region ${AWS_REGION}",
        "aws s3 cp /tmp/deployment-scripts/setup-node.sh \"s3://${S3_BUCKET}/${S3_SCRIPTS_PREFIX}/setup-node.sh\" --region ${AWS_REGION}",
        "echo '[OK] Uploaded to S3'"
      ]
    },
    {
      "id": "08-verify-s3-upload",
      "name": "Verify S3 upload",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Verifying S3 upload...'",
        "aws s3 ls \"s3://${S3_BUCKET}/${S3_PLUGIN_KEY}\" --region ${AWS_REGION}",
        "aws s3 ls \"s3://${S3_BUCKET}/${S3_SCRIPTS_PREFIX}/setup-node.sh\" --region ${AWS_REGION}",
        "echo '[OK] S3 upload verified'"
      ]
    },
    {
      "id": "09-check-node-connectivity",
      "name": "Check SSH connectivity to both nodes",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Checking SSH connectivity...'",
        "ssh -i \"${SSH_KEY}\" -o StrictHostKeyChecking=no -o ConnectTimeout=10 ${REMOTE_USER}@${NODE1_PUBLIC_IP} 'echo [OK] Node1 reachable'",
        "ssh -i \"${SSH_KEY}\" -o StrictHostKeyChecking=no -o ConnectTimeout=10 ${REMOTE_USER}@${NODE2_PUBLIC_IP} 'echo [OK] Node2 reachable'",
        "echo '[OK] Both nodes reachable'"
      ]
    },
    {
      "id": "10-setup-node1-producer",
      "name": "Setup Node1 as Producer",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Setting up Node1 (Producer)...'",
        "ssh -i \"${SSH_KEY}\" -o StrictHostKeyChecking=no ${REMOTE_USER}@${NODE1_PUBLIC_IP} << 'EOSSH'",
        "set -e",
        "aws s3 cp s3://${S3_BUCKET}/${S3_SCRIPTS_PREFIX}/setup-node.sh /tmp/setup-node.sh --region ${AWS_REGION} --quiet",
        "chmod +x /tmp/setup-node.sh",
        "/tmp/setup-node.sh producer ${NODE2_PRIVATE_IP} ${S3_BUCKET} ${AWS_REGION} ${MODEL_NAME} ${PRODUCER_PORT}",
        "EOSSH",
        "echo '[OK] Node1 setup complete'"
      ]
    },
    {
      "id": "11-setup-node2-consumer",
      "name": "Setup Node2 as Consumer",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Setting up Node2 (Consumer)...'",
        "ssh -i \"${SSH_KEY}\" -o StrictHostKeyChecking=no ${REMOTE_USER}@${NODE2_PUBLIC_IP} << 'EOSSH'",
        "set -e",
        "aws s3 cp s3://${S3_BUCKET}/${S3_SCRIPTS_PREFIX}/setup-node.sh /tmp/setup-node.sh --region ${AWS_REGION} --quiet",
        "chmod +x /tmp/setup-node.sh",
        "/tmp/setup-node.sh consumer ${NODE2_PRIVATE_IP} ${S3_BUCKET} ${AWS_REGION} ${MODEL_NAME} ${CONSUMER_PORT}",
        "EOSSH",
        "echo '[OK] Node2 setup complete'"
      ]
    },
    {
      "id": "12-verify-plugin-deployment",
      "name": "Verify plugin deployment on both nodes",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Verifying plugin deployment...'",
        "NODE1_MD5=$(ssh -i \"${SSH_KEY}\" -o StrictHostKeyChecking=no ${REMOTE_USER}@${NODE1_PUBLIC_IP} \"python3 -c 'import nixl, os; plugin_dir = os.path.join(os.path.dirname(nixl.__file__), \\\"../.nixl_cu12.mesonpy.libs/plugins\\\"); import hashlib; print(hashlib.md5(open(os.path.join(plugin_dir, \\\"libplugin_LIBFABRIC.so\\\"), \\\"rb\\\").read()).hexdigest())' 2>/dev/null || python3 -c 'import nixl, os; plugin_dir = os.path.join(os.path.dirname(nixl.__file__), \\\"_lib\\\"); import hashlib; print(hashlib.md5(open(os.path.join(plugin_dir, \\\"libplugin_LIBFABRIC.so\\\"), \\\"rb\\\").read()).hexdigest())'\")",
        "NODE2_MD5=$(ssh -i \"${SSH_KEY}\" -o StrictHostKeyChecking=no ${REMOTE_USER}@${NODE2_PUBLIC_IP} \"python3 -c 'import nixl, os; plugin_dir = os.path.join(os.path.dirname(nixl.__file__), \\\"../.nixl_cu12.mesonpy.libs/plugins\\\"); import hashlib; print(hashlib.md5(open(os.path.join(plugin_dir, \\\"libplugin_LIBFABRIC.so\\\"), \\\"rb\\\").read()).hexdigest())' 2>/dev/null || python3 -c 'import nixl, os; plugin_dir = os.path.join(os.path.dirname(nixl.__file__), \\\"_lib\\\"); import hashlib; print(hashlib.md5(open(os.path.join(plugin_dir, \\\"libplugin_LIBFABRIC.so\\\"), \\\"rb\\\").read()).hexdigest())'\")",
        "PLUGIN_PATH=\"${NIXL_CLONE_DIR}/${BUILD_SUBDIR}/${PLUGIN_RELATIVE_PATH}\"",
        "LOCAL_MD5=$(md5sum \"${PLUGIN_PATH}\" | awk '{print $1}')",
        "echo \"Local:  ${LOCAL_MD5}\"",
        "echo \"Node1:  ${NODE1_MD5}\"",
        "echo \"Node2:  ${NODE2_MD5}\"",
        "if [ \"${NODE1_MD5}\" = \"${LOCAL_MD5}\" ] && [ \"${NODE2_MD5}\" = \"${LOCAL_MD5}\" ]; then echo '[OK] All MD5 match'; else echo '[ERROR] MD5 mismatch'; exit 1; fi"
      ]
    },
    {
      "id": "13-display-summary",
      "name": "Display deployment summary",
      "skip_if": "",
      "commands": [
        "echo ''",
        "echo '========================================='",
        "echo 'Complete Deployment Summary'",
        "echo '========================================='",
        "echo ''",
        "echo 'Source:'",
        "echo \"  Repository: ${NIXL_REPO}\"",
        "echo \"  Branch:     ${NIXL_BRANCH}\"",
        "cd \"${NIXL_CLONE_DIR}\" && echo \"  Commit:     $(git log --oneline -1)\"",
        "echo ''",
        "echo 'Plugin:'",
        "PLUGIN_PATH=\"${NIXL_CLONE_DIR}/${BUILD_SUBDIR}/${PLUGIN_RELATIVE_PATH}\"",
        "echo \"  Path:   ${PLUGIN_PATH}\"",
        "echo \"  Size:   $(stat -c '%s' \"${PLUGIN_PATH}\") bytes\"",
        "echo \"  MD5:    $(md5sum \"${PLUGIN_PATH}\" | awk '{print $1}')\"",
        "echo ''",
        "echo 'S3:'",
        "echo \"  Bucket: s3://${S3_BUCKET}\"",
        "echo \"  Plugin: ${S3_PLUGIN_KEY}\"",
        "echo \"  Script: ${S3_SCRIPTS_PREFIX}/setup-node.sh\"",
        "echo ''",
        "echo 'Nodes:'",
        "echo \"  Node1 (Producer): ${NODE1_PUBLIC_IP} [OK]\"",
        "echo \"  Node2 (Consumer): ${NODE2_PUBLIC_IP} [OK]\"",
        "echo ''",
        "echo 'Next steps:'",
        "echo '  1. Start Consumer (Node2):'",
        "echo \"     ssh -i ${SSH_KEY} ubuntu@${NODE2_PUBLIC_IP} '/tmp/start-vllm.sh' &\"",
        "echo ''",
        "echo '  2. Start Producer (Node1):'",
        "echo \"     ssh -i ${SSH_KEY} ubuntu@${NODE1_PUBLIC_IP} '/tmp/start-vllm.sh' &\"",
        "echo ''",
        "echo '  3. Wait for model loading (5-10 minutes)'",
        "echo ''",
        "echo '  4. Test API:'",
        "echo \"     curl -X POST http://${NODE2_PUBLIC_IP}:${CONSUMER_PORT}/v1/completions \\\\\"",
        "echo \"       -H 'Content-Type: application/json' \\\\\"",
        "echo \"       -d '{\\\"model\\\": \\\"${MODEL_NAME}\\\", \\\"prompt\\\": \\\"Hello\\\", \\\"max_tokens\\\": 10}'\"",
        "echo ''",
        "echo '[SUCCESS] Deployment complete!'"
      ]
    }
  ]
}
