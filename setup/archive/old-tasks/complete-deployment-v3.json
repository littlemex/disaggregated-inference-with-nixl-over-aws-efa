{
  "name": "Complete NIXL LIBFABRIC Deployment - Producer/Consumer Separated",
  "description": "完全自動化されたデプロイメント: GitHub clone → ビルド → S3 → EC2セットアップ → vLLM起動。Producer/Consumer の環境変数を分離。",
  "environment": {
    "NIXL_REPO": "${NIXL_REPO:-https://github.com/littlemex/nixl.git}",
    "NIXL_BRANCH": "${NIXL_BRANCH:-main}",
    "NIXL_CLONE_DIR": "${NIXL_CLONE_DIR:-/tmp/nixl-build}",
    "BUILD_SUBDIR": "${BUILD_SUBDIR:-build}",
    "PLUGIN_RELATIVE_PATH": "${PLUGIN_RELATIVE_PATH:-src/plugins/libfabric/libplugin_LIBFABRIC.so}",
    "S3_BUCKET": "${S3_BUCKET}",
    "S3_PLUGIN_KEY": "${S3_PLUGIN_KEY:-plugins/libplugin_LIBFABRIC.so}",
    "AWS_REGION": "${AWS_REGION}",
    "SSH_KEY": "${SSH_KEY}",
    "REMOTE_USER": "${REMOTE_USER:-ubuntu}",
    "NODE1_PUBLIC_IP": "${NODE1_PUBLIC_IP}",
    "NODE1_PRIVATE_IP": "${NODE1_PRIVATE_IP}",
    "NODE2_PUBLIC_IP": "${NODE2_PUBLIC_IP}",
    "NODE2_PRIVATE_IP": "${NODE2_PRIVATE_IP}",
    "PRODUCER_ENGINE_ID": "${PRODUCER_ENGINE_ID:-producer-1}",
    "PRODUCER_PORT": "${PRODUCER_PORT:-8100}",
    "PRODUCER_NIXL_ENGINE": "${PRODUCER_NIXL_ENGINE:-producer}",
    "CONSUMER_ENGINE_ID": "${CONSUMER_ENGINE_ID:-consumer-1}",
    "CONSUMER_PORT": "${CONSUMER_PORT:-8200}",
    "CONSUMER_NIXL_ENGINE": "${CONSUMER_NIXL_ENGINE:-consumer}",
    "NIXL_PORT": "${NIXL_PORT:-14579}",
    "MODEL_NAME": "${MODEL_NAME:-Qwen/Qwen2.5-32B-Instruct}",
    "TENSOR_PARALLEL_SIZE": "${TENSOR_PARALLEL_SIZE:-2}",
    "GPU_MEMORY_UTILIZATION": "${GPU_MEMORY_UTILIZATION:-0.9}",
    "MAX_MODEL_LEN": "${MAX_MODEL_LEN:-32000}",
    "MAX_NUM_BATCHED_TOKENS": "${MAX_NUM_BATCHED_TOKENS:-8192}",
    "KV_BUFFER_SIZE": "${KV_BUFFER_SIZE:-5000000000}",
    "KV_BUFFER_DEVICE": "${KV_BUFFER_DEVICE:-cpu}"
  },
  "tasks": [
    {
      "id": "00-check-libfabric-dev",
      "name": "Check libfabric-dev installation",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Checking libfabric-dev installation...'",
        "if ! dpkg -l | grep -q libfabric-dev; then",
        "  echo '[ERROR] libfabric-dev is not installed'",
        "  echo ''",
        "  echo 'Please install libfabric-dev first:'",
        "  echo '  sudo apt-get update'",
        "  echo '  sudo apt-get install -y libfabric-dev'",
        "  echo ''",
        "  echo 'After installation, re-run this script.'",
        "  exit 1",
        "fi",
        "echo '[OK] libfabric-dev is installed'"
      ]
    },
    {
      "id": "01-check-local-prerequisites",
      "name": "Check local prerequisites (git, ninja, meson, aws)",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Checking local prerequisites...'",
        "command -v git >/dev/null 2>&1 || { echo '[ERROR] git not found'; exit 1; }",
        "command -v ninja >/dev/null 2>&1 || { echo '[ERROR] ninja not found. Install: pip install ninja'; exit 1; }",
        "command -v meson >/dev/null 2>&1 || { echo '[ERROR] meson not found. Install: pip install meson'; exit 1; }",
        "command -v aws >/dev/null 2>&1 || { echo '[ERROR] aws CLI not found'; exit 1; }",
        "echo '[OK] All prerequisites satisfied'"
      ]
    },
    {
      "id": "02-clone-nixl-from-github",
      "name": "Clone or update NIXL from GitHub",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Cloning NIXL from GitHub...'",
        "if [ -d \"${NIXL_CLONE_DIR}/.git\" ]; then",
        "  cd \"${NIXL_CLONE_DIR}\" && git fetch origin && git checkout ${NIXL_BRANCH} && git pull origin ${NIXL_BRANCH}",
        "else",
        "  rm -rf \"${NIXL_CLONE_DIR}\" && git clone \"${NIXL_REPO}\" \"${NIXL_CLONE_DIR}\" && cd \"${NIXL_CLONE_DIR}\" && git checkout ${NIXL_BRANCH}",
        "fi",
        "cd \"${NIXL_CLONE_DIR}\" && git log --oneline -1",
        "echo '[OK] NIXL source ready'"
      ]
    },
    {
      "id": "03-verify-request-response-protocol",
      "name": "Verify Request/Response protocol implementation",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Verifying Request/Response protocol...'",
        "grep -q 'loadRemoteConnInfo' \"${NIXL_CLONE_DIR}/src/plugins/libfabric/libfabric_backend.h\" || { echo '[ERROR] loadRemoteConnInfo not found'; exit 1; }",
        "grep -q 'remote_conn_info' \"${NIXL_CLONE_DIR}/src/plugins/libfabric/libfabric_backend.cpp\" || { echo '[ERROR] remote_conn_info implementation not found'; exit 1; }",
        "echo '[OK] Request/Response protocol verified'"
      ]
    },
    {
      "id": "04-setup-meson-build",
      "name": "Setup meson build directory",
      "skip_if": "test -f ${NIXL_CLONE_DIR}/${BUILD_SUBDIR}/build.ninja",
      "commands": [
        "echo '[INFO] Setting up meson build...'",
        "cd \"${NIXL_CLONE_DIR}\" && meson setup ${BUILD_SUBDIR} --prefix=/usr/local",
        "echo '[OK] Meson configured'"
      ]
    },
    {
      "id": "05-build-nixl-plugin",
      "name": "Build NIXL LIBFABRIC plugin",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Building NIXL plugin...'",
        "cd \"${NIXL_CLONE_DIR}/${BUILD_SUBDIR}\" && ninja",
        "test -f \"${NIXL_CLONE_DIR}/${BUILD_SUBDIR}/${PLUGIN_RELATIVE_PATH}\" || { echo '[ERROR] Plugin build failed'; exit 1; }",
        "echo '[OK] Plugin built successfully'"
      ]
    },
    {
      "id": "06-verify-plugin-artifact",
      "name": "Verify plugin artifact",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Verifying plugin artifact...'",
        "PLUGIN_PATH=\"${NIXL_CLONE_DIR}/${BUILD_SUBDIR}/${PLUGIN_RELATIVE_PATH}\"",
        "SO_SIZE=$(stat -c '%s' \"${PLUGIN_PATH}\")",
        "SO_SIZE_KB=$((SO_SIZE / 1024))",
        "echo \"[OK] Size: ${SO_SIZE_KB} KB\"",
        "file \"${PLUGIN_PATH}\" | grep -q 'ELF.*shared object' || { echo '[ERROR] Not a valid ELF shared object'; exit 1; }",
        "echo '[OK] Plugin artifact verified'"
      ]
    },
    {
      "id": "07-upload-to-s3",
      "name": "Upload plugin to S3",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Uploading plugin to S3...'",
        "PLUGIN_PATH=\"${NIXL_CLONE_DIR}/${BUILD_SUBDIR}/${PLUGIN_RELATIVE_PATH}\"",
        "aws s3 cp \"${PLUGIN_PATH}\" \"s3://${S3_BUCKET}/${S3_PLUGIN_KEY}\" --region ${AWS_REGION}",
        "aws s3 ls \"s3://${S3_BUCKET}/${S3_PLUGIN_KEY}\" --region ${AWS_REGION} || { echo '[ERROR] S3 upload verification failed'; exit 1; }",
        "echo '[OK] Plugin uploaded to S3'"
      ]
    },
    {
      "id": "08-check-node-connectivity",
      "name": "Check SSH connectivity to both nodes",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Testing SSH connectivity...'",
        "ssh -i \"${SSH_KEY}\" -o StrictHostKeyChecking=no -o ConnectTimeout=10 \"${REMOTE_USER}@${NODE1_PUBLIC_IP}\" 'echo \"[OK] Node1 connected\"' || { echo '[ERROR] Cannot connect to Node1'; exit 1; }",
        "ssh -i \"${SSH_KEY}\" -o StrictHostKeyChecking=no -o ConnectTimeout=10 \"${REMOTE_USER}@${NODE2_PUBLIC_IP}\" 'echo \"[OK] Node2 connected\"' || { echo '[ERROR] Cannot connect to Node2'; exit 1; }",
        "echo '[OK] SSH connectivity verified'"
      ]
    },
    {
      "id": "09-setup-node1-producer",
      "name": "Setup Node1 as Producer with vLLM + NIXL",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Setting up Node1 as Producer...'",
        "ssh -i \"${SSH_KEY}\" -o StrictHostKeyChecking=no \"${REMOTE_USER}@${NODE1_PUBLIC_IP}\" << ENDSSH",
        "set -e",
        "",
        "echo '[STEP 1/5] Installing vLLM v0.17.0...'",
        "python3 -m pip install --no-cache-dir 'vllm==0.17.0' --user -q || { echo '[ERROR] vLLM install failed'; exit 1; }",
        "python3 -c 'import vllm; print(f\"[OK] vLLM {vllm.__version__} installed\")'",
        "",
        "echo '[STEP 2/5] Installing NIXL v0.10.0...'",
        "python3 -m pip install --no-cache-dir 'nixl[cu12]' --user -q || { echo '[ERROR] NIXL install failed'; exit 1; }",
        "python3 -c 'import nixl; print(\"[OK] NIXL installed\")'",
        "",
        "echo '[STEP 3/5] Deploying custom LIBFABRIC plugin...'",
        "NIXL_DIR=\\$(python3 -c 'import nixl; import os; print(os.path.dirname(nixl.__file__))')",
        "PLUGIN_DIR=\"\\${NIXL_DIR}/_lib\"",
        "aws s3 cp \"s3://${S3_BUCKET}/${S3_PLUGIN_KEY}\" \"\\${PLUGIN_DIR}/libplugin_LIBFABRIC.so\" --region ${AWS_REGION} --quiet || { echo '[ERROR] Plugin download failed'; exit 1; }",
        "chmod 755 \"\\${PLUGIN_DIR}/libplugin_LIBFABRIC.so\"",
        "ls -lh \"\\${PLUGIN_DIR}/libplugin_LIBFABRIC.so\"",
        "",
        "echo '[STEP 4/5] Creating Producer startup script...'",
        "mkdir -p ~/nixl-producer",
        "cat > ~/nixl-producer/start_producer.sh << 'PRODUCER_SCRIPT'",
        "#!/bin/bash",
        "export NIXL_ENGINE=${PRODUCER_NIXL_ENGINE}",
        "export ENGINE_ID=${PRODUCER_ENGINE_ID}",
        "export NIXL_PORT=${NIXL_PORT}",
        "export KV_BUFFER_DEVICE=${KV_BUFFER_DEVICE}",
        "export CONSUMER_ADDR=${NODE2_PRIVATE_IP}:${CONSUMER_PORT}",
        "",
        "vllm serve ${MODEL_NAME} \\\\",
        "  --port ${PRODUCER_PORT} \\\\",
        "  --tensor-parallel-size ${TENSOR_PARALLEL_SIZE} \\\\",
        "  --gpu-memory-utilization ${GPU_MEMORY_UTILIZATION} \\\\",
        "  --max-model-len ${MAX_MODEL_LEN} \\\\",
        "  --max-num-batched-tokens ${MAX_NUM_BATCHED_TOKENS} \\\\",
        "  --kv-buffer-size ${KV_BUFFER_SIZE} \\\\",
        "  --kv-buffer-device \\${KV_BUFFER_DEVICE} \\\\",
        "  --trust-remote-code",
        "PRODUCER_SCRIPT",
        "chmod +x ~/nixl-producer/start_producer.sh",
        "",
        "echo '[STEP 5/5] Verifying setup...'",
        "python3 -c 'import nixl; import os; plugin_dir = os.path.join(os.path.dirname(nixl.__file__), \"_lib\"); plugins = [f for f in os.listdir(plugin_dir) if f.startswith(\"libplugin_\") and f.endswith(\".so\")]; print(f\"[OK] Plugins: {plugins}\"); assert \"libplugin_LIBFABRIC.so\" in plugins'",
        "echo '[SUCCESS] Node1 (Producer) setup complete'",
        "echo ''",
        "echo 'Producer configuration:'",
        "echo '  ENGINE_ID: ${PRODUCER_ENGINE_ID}'",
        "echo '  NIXL_ENGINE: ${PRODUCER_NIXL_ENGINE}'",
        "echo '  PORT: ${PRODUCER_PORT}'",
        "echo '  CONSUMER_ADDR: ${NODE2_PRIVATE_IP}:${CONSUMER_PORT}'",
        "echo ''",
        "echo 'To start Producer:'",
        "echo '  cd ~/nixl-producer && ./start_producer.sh'",
        "",
        "ENDSSH",
        "echo '[OK] Node1 (Producer) setup complete'"
      ]
    },
    {
      "id": "10-setup-node2-consumer",
      "name": "Setup Node2 as Consumer with vLLM + NIXL",
      "skip_if": "",
      "commands": [
        "echo '[INFO] Setting up Node2 as Consumer...'",
        "ssh -i \"${SSH_KEY}\" -o StrictHostKeyChecking=no \"${REMOTE_USER}@${NODE2_PUBLIC_IP}\" << ENDSSH",
        "set -e",
        "",
        "echo '[STEP 1/5] Installing vLLM v0.17.0...'",
        "python3 -m pip install --no-cache-dir 'vllm==0.17.0' --user -q || { echo '[ERROR] vLLM install failed'; exit 1; }",
        "python3 -c 'import vllm; print(f\"[OK] vLLM {vllm.__version__} installed\")'",
        "",
        "echo '[STEP 2/5] Installing NIXL v0.10.0...'",
        "python3 -m pip install --no-cache-dir 'nixl[cu12]' --user -q || { echo '[ERROR] NIXL install failed'; exit 1; }",
        "python3 -c 'import nixl; print(\"[OK] NIXL installed\")'",
        "",
        "echo '[STEP 3/5] Deploying custom LIBFABRIC plugin...'",
        "NIXL_DIR=\\$(python3 -c 'import nixl; import os; print(os.path.dirname(nixl.__file__))')",
        "PLUGIN_DIR=\"\\${NIXL_DIR}/_lib\"",
        "aws s3 cp \"s3://${S3_BUCKET}/${S3_PLUGIN_KEY}\" \"\\${PLUGIN_DIR}/libplugin_LIBFABRIC.so\" --region ${AWS_REGION} --quiet || { echo '[ERROR] Plugin download failed'; exit 1; }",
        "chmod 755 \"\\${PLUGIN_DIR}/libplugin_LIBFABRIC.so\"",
        "ls -lh \"\\${PLUGIN_DIR}/libplugin_LIBFABRIC.so\"",
        "",
        "echo '[STEP 4/5] Creating Consumer startup script...'",
        "mkdir -p ~/nixl-consumer",
        "cat > ~/nixl-consumer/start_consumer.sh << 'CONSUMER_SCRIPT'",
        "#!/bin/bash",
        "export NIXL_ENGINE=${CONSUMER_NIXL_ENGINE}",
        "export ENGINE_ID=${CONSUMER_ENGINE_ID}",
        "export NIXL_PORT=${NIXL_PORT}",
        "export KV_BUFFER_DEVICE=${KV_BUFFER_DEVICE}",
        "",
        "vllm serve ${MODEL_NAME} \\\\",
        "  --port ${CONSUMER_PORT} \\\\",
        "  --tensor-parallel-size ${TENSOR_PARALLEL_SIZE} \\\\",
        "  --gpu-memory-utilization ${GPU_MEMORY_UTILIZATION} \\\\",
        "  --max-model-len ${MAX_MODEL_LEN} \\\\",
        "  --max-num-batched-tokens ${MAX_NUM_BATCHED_TOKENS} \\\\",
        "  --kv-buffer-size ${KV_BUFFER_SIZE} \\\\",
        "  --kv-buffer-device \\${KV_BUFFER_DEVICE} \\\\",
        "  --trust-remote-code",
        "CONSUMER_SCRIPT",
        "chmod +x ~/nixl-consumer/start_consumer.sh",
        "",
        "echo '[STEP 5/5] Verifying setup...'",
        "python3 -c 'import nixl; import os; plugin_dir = os.path.join(os.path.dirname(nixl.__file__), \"_lib\"); plugins = [f for f in os.listdir(plugin_dir) if f.startswith(\"libplugin_\") and f.endswith(\".so\")]; print(f\"[OK] Plugins: {plugins}\"); assert \"libplugin_LIBFABRIC.so\" in plugins'",
        "echo '[SUCCESS] Node2 (Consumer) setup complete'",
        "echo ''",
        "echo 'Consumer configuration:'",
        "echo '  ENGINE_ID: ${CONSUMER_ENGINE_ID}'",
        "echo '  NIXL_ENGINE: ${CONSUMER_NIXL_ENGINE}'",
        "echo '  PORT: ${CONSUMER_PORT}'",
        "echo ''",
        "echo 'To start Consumer:'",
        "echo '  cd ~/nixl-consumer && ./start_consumer.sh'",
        "",
        "ENDSSH",
        "echo '[OK] Node2 (Consumer) setup complete'"
      ]
    },
    {
      "id": "11-display-summary",
      "name": "Display deployment summary",
      "skip_if": "",
      "commands": [
        "echo ''",
        "echo '========================================='",
        "echo 'Deployment Complete!'",
        "echo '========================================='",
        "echo ''",
        "echo 'Producer (Node1):'",
        "echo '  Public IP:  ${NODE1_PUBLIC_IP}'",
        "echo '  Private IP: ${NODE1_PRIVATE_IP}'",
        "echo '  ENGINE_ID:  ${PRODUCER_ENGINE_ID}'",
        "echo '  Port:       ${PRODUCER_PORT}'",
        "echo ''",
        "echo 'Consumer (Node2):'",
        "echo '  Public IP:  ${NODE2_PUBLIC_IP}'",
        "echo '  Private IP: ${NODE2_PRIVATE_IP}'",
        "echo '  ENGINE_ID:  ${CONSUMER_ENGINE_ID}'",
        "echo '  Port:       ${CONSUMER_PORT}'",
        "echo ''",
        "echo 'Next steps:'",
        "echo '  1. Start Consumer: ssh -i ${SSH_KEY} ${REMOTE_USER}@${NODE2_PUBLIC_IP} \"cd ~/nixl-consumer && ./start_consumer.sh\"'",
        "echo '  2. Start Producer: ssh -i ${SSH_KEY} ${REMOTE_USER}@${NODE1_PUBLIC_IP} \"cd ~/nixl-producer && ./start_producer.sh\"'",
        "echo '  3. Run benchmark tests'",
        "echo ''"
      ]
    }
  ]
}
