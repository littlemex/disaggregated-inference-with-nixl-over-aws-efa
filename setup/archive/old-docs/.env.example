# Phase 3 NIXL LIBFABRIC Backend Fix - Environment Variables
#
# Usage:
#   cp .env.example .env
#   # Edit .env with actual values
#   source .env
#   bash task_runner.sh tasks/verify-backend-fix.json
#
# Note: All variables below are required unless marked (optional).

# --------------------------------------------------
# Node Information
# --------------------------------------------------

# Node1 (Producer) - Public IP for SSH access
NODE1_PUBLIC_IP=44.247.215.228

# Node2 (Consumer) - Public IP for SSH access
NODE2_PUBLIC_IP=34.217.117.205

# Node1 (Producer) - Private IP for inter-node communication
NODE1_PRIVATE_IP=172.31.2.221

# Node2 (Consumer) - Private IP for inter-node communication
NODE2_PRIVATE_IP=172.31.10.117

# --------------------------------------------------
# SSH Configuration
# --------------------------------------------------

# Path to SSH private key for EC2 access
SSH_KEY=/home/coder/.ssh/phase3_key

# --------------------------------------------------
# S3 Configuration
# --------------------------------------------------

# S3 bucket for plugin artifacts
S3_BUCKET=phase3-nixl-efa-dev-west-2-scriptsbucket40feb4b1-ougyvcmrbyjj

# --------------------------------------------------
# vLLM Configuration
# --------------------------------------------------

# Model name (must match on Producer and Consumer)
MODEL_NAME=Qwen/Qwen2.5-32B-Instruct

# Engine ID (must match on Producer and Consumer)
ENGINE_ID=phase3-nixl-efa-di-20260307

# Producer port on Node1
PRODUCER_PORT=8100

# Consumer port on Node2
CONSUMER_PORT=8200

# Proxy Server port on Node1 (optional, used in summary)
PROXY_PORT=8000

# --------------------------------------------------
# AWS Configuration
# --------------------------------------------------

# AWS region for S3 and SSM operations
AWS_REGION=us-west-2

# --------------------------------------------------
# Instance IDs (for SSM, optional - SSH is primary)
# --------------------------------------------------

# Node1 Instance ID
# NODE1_INSTANCE_ID=i-050ac7e7a9986ccc7

# Node2 Instance ID
# NODE2_INSTANCE_ID=i-0634bbcbb9d65d4e3
